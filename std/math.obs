
fn sqrt(n: f64) f64 {
    ret n ** ( 0.5 );
};

fn pythagoras(a: f64, b: f64) f64 {
    ret sqrt(a ** 2 + b ** 2);
};

fn factorial(n: i32) {
    ? n < 0 {
        $n; $$" must be non-negative";
    };

    #@res = 1;
    #@i = 2;
    £ i < n + 1 {
        res = res * i;
        i = i + 1;
    };
    ret res;
};

