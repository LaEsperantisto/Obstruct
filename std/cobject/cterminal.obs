cls CTerminal {
    buffer: strlit
};

fn show(terminal: &CTerminal) {
    $"\x1B[2J\x1B[1;1H";
    $*terminal.buffer;
};

fn add_str(terminal: &CTerminal, s: strlit) {
    terminal.buffer = terminal.buffer + s;
};

fn new() CTerminal {
    #terminal: CTerminal;
    terminal.buffer = `s;
    ret terminal;
};